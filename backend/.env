# Environment Variables — Backend
# Copy this file to .env and fill in real values

# ── Server ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CLIENT_URL=*

# ── Database ─────────────────────────────────────────────────────
# MySQL (Legacy)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=smart_fence
DB_USER=root
DB_PASSWORD=rootpass

# MongoDB Atlas (Production)
MONGODB_URI=mongodb+srv://wassim:Wassimakkari1@smartfence.7zypd8b.mongodb.net/smartfence_db?retryWrites=true&w=majority&appName=smartfence
# MONGODB_URI=mongodb://127.0.0.1:27017/smart_fence (Local Fallback)

# ── AI Service ───────────────────────────────────────────────────
