# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_32_chars_minimum_here!
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=ANOTHER_RANDOM_SECRET_64_chars!!
