DB_PORT=3306
DB_NAME=smart_fence
DB_USER=root
DB_PASSWORD=rootpass

# MongoDB (New)
MONGODB_URI=mongodb://wassim:Wassimakkari1@ac-lokdmj8-shard-00-00.7zypd8b.mongodb.net:27017,ac-lokdmj8-shard-00-01.7zypd8b.mongodb.net:27017,ac-lokdmj8-shard-00-02.7zypd8b.mongodb.net:27017/smart_fence?ssl=true&replicaSet=atlas-vzylfb-shard-0&authSource=admin&appName=smartfence
