# Environment Variables — Backend
# Copy this file to .env and fill in real values

# ── Server ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:8081

# ── Database ─────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=smart_fence
DB_USER=root
DB_PASSWORD=rootpass

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_32_chars_minimum_here!
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=ANOTHER_RANDOM_SECRET_64_chars!!
JWT_REFRESH_EXPIRES_IN=7d

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=info
